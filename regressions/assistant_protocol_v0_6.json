    {
      "id": "TC-S01",
      "title": "意图识别后立即推流",
      "purpose": "可识别消息必须先推 intent_recognition 帧，再推业务状态帧。",
      "status": "covered_by_protocol_validator",
      "tags": [
        "message",
        "stream",
        "intent_recognition",
        "slot_filling"
      ],
      "steps": [
        {
          "name": "message_missing_amount",
          "endpoint": "/api/v1/message",
          "stream": true,
          "request": {
            "sessionId": "assistant_tc_s01",
            "txt": "给小明转账",
            "stream": true,
            "custID": "C0001"
          },
          "expectations": [
            {
              "kind": "top_level_contract"
            },
            {
              "kind": "intent_recognized_before_business"
            },
            {
              "kind": "business_frame",
              "status": "waiting_user_input",
              "completion_reason": "router_waiting_user_input",
              "slot_contains": {
                "payee_name": "小明"
              }
            },
            {
              "kind": "done"
            }
          ]
        }
      ]
    },
