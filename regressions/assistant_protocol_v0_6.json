          "endpoint": "/api/v1/message",
          "stream": true,
          "request": {
            "sessionId": "assistant_tc_s01",
            "txt": "200",
            "stream": true,
            "custID": "C0001"
          },
          "expectations": [
            {
              "kind": "top_level_contract"
            },
            {
              "kind": "intent_recognized_before_business"
