    {
      "id": "TC-S09",
      "title": "多意图 / 待确认图",
      "purpose": "多意图输入不能被压成一个单任务结果，必须暴露任务列表或待确认图。",
      "status": "needs_external_stream_runner",
      "tags": [
        "message",
        "stream",
        "multi_intent",
        "graph"
      ],
      "steps": [
        {
          "name": "multi_intent_message",
          "endpoint": "/api/v1/message",
          "stream": true,
          "request": {
            "sessionId": "assistant_tc_s09",
            "txt": "先查余额，再给张三转账 200 元，卡号 6222020100049999999，尾号 1234",
            "stream": true,
            "custID": "C0001"
          },
          "expectations": [
            {
              "kind": "intent_recognized_before_business"
            },
            {
              "kind": "task_list_min",
              "minimum": 2
            },
            {
              "kind": "current_task_in_task_list"
            },
            {
              "kind": "recognition_order_matches_task_list"
            },
            {
              "kind": "graph_nodes_order_matches_task_list"
            },
            {
              "kind": "done"
            }
          ]
        }
      ],
      "notes": [
        "覆盖矩阵 S17 / PR #8 的识别帧、task_list 和 graph nodes 顺序一致性要求。"
      ]
    },
